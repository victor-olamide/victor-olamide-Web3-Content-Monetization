# Environment Variables - Pay-Per-View Configuration
# Copy this file to .env and fill in the values

# ═══════════════════════════════════════════════════════════════════
# STACKS BLOCKCHAIN CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Network environment: 'testnet' or 'mainnet'
STACKS_NETWORK=testnet

# Stacks API URL (defaults based on STACKS_NETWORK if not set)
STACKS_API_URL=https://stacks-node-api.testnet.stacks.co

# Private key for contract deployment (testnet - save this securely!)
# Generate from: https://www.stacks.co/generate-address
STACKS_PRIVATE_KEY=your_private_key_here_keep_this_secret

# ═══════════════════════════════════════════════════════════════════
# PAY-PER-VIEW CONTRACT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Deployed contract owner/deployer address
# This is automatically detected during deployment
PAY_PER_VIEW_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM

# Platform fee in basis points (100 = 1%)
# Default: 250 basis points (2.5%)
PLATFORM_FEE_BASIS_POINTS=250

# Platform wallet to receive fees
# Set to your platform's primary wallet address
PLATFORM_WALLET=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM

# Refund window in blocks (~144 blocks = 24 hours on Bitcoin)
# Default: 144 blocks
PPV_REFUND_WINDOW=144

# ═══════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Primary MongoDB connection URI
# Format: mongodb://[username:password@]host[:port]/database
DB_URI=mongodb://localhost:27017/stacks_monetization

# Fallback MongoDB URI (for backward compatibility)
MONGODB_URI=mongodb://localhost:27017/stacks_monetization

# MongoDB connection pool settings
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=2
MONGO_CONNECT_RETRIES=3
MONGO_CONNECT_RETRY_DELAY_MS=3000

# ═══════════════════════════════════════════════════════════════════
# CACHING CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Cache TTL in milliseconds
# Default: 300000ms (5 minutes)
CACHE_TTL=300000

# Redis configuration (optional, for distributed caching)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# ═══════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Server port
PORT=3000

# Node environment
NODE_ENV=development

# API base URL (for external references)
API_BASE_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════
# LOGGING CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Log level: 'debug', 'info', 'warn', 'error'
LOG_LEVEL=info

# Log file path
LOG_FILE=/var/log/stacks-monetization.log

# ═══════════════════════════════════════════════════════════════════
# PAYMENT VERIFICATION CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Minimum confirmations required before access granted
PAYMENT_MIN_CONFIRMATIONS=3

# Transaction verification timeout (milliseconds)
TX_VERIFICATION_TIMEOUT=30000

# Maximum polling attempts for transaction confirmation
TX_POLLING_MAX_ATTEMPTS=60

# Initial polling delay (exponential backoff)
TX_POLLING_INITIAL_DELAY_MS=1000

# ═══════════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════════

# Enable on-chain purchase verification
FEATURE_PPV_ON_CHAIN_VERIFICATION=true

# Enable automatic cache invalidation
FEATURE_AUTO_CACHE_INVALIDATION=true

# Enable purchase audit logging
FEATURE_PURCHASE_AUDIT_LOG=true

# ═══════════════════════════════════════════════════════════════════
# THIRD-PARTY SERVICES
# ═══════════════════════════════════════════════════════════════════

# Email service for notifications
EMAIL_SERVICE_ENABLED=false
EMAIL_SERVICE_API_KEY=your_email_service_key
EMAIL_FROM_ADDRESS=noreply@platform.com

# Analytics service
ANALYTICS_ENABLED=false
ANALYTICS_API_KEY=your_analytics_key

# ═══════════════════════════════════════════════════════════════════
# SECURITY CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# JWT secret for API authentication
JWT_SECRET=your_jwt_secret_keep_this_secure

# Rate limiting (requests per minute)
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# CORS configuration
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# ═══════════════════════════════════════════════════════════════════
# TESTING CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Test database URI
MONGODB_TEST_URI=mongodb://localhost:27017/stacks_monetization_test

# Test mode (for skipping certain validations)
TEST_MODE=false

# ═══════════════════════════════════════════════════════════════════
# DEPLOYMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Deployment environment: 'development', 'staging', 'production'
DEPLOYMENT_ENV=development

# Flag to enable maintenance mode
MAINTENANCE_MODE=false

# Maintenance message displayed to users
MAINTENANCE_MESSAGE=System maintenance in progress. Please try again later.
