# ============================================================
# REQUIRED — Server must have these set to start correctly
# ============================================================

# HTTP port the Express server listens on
PORT=5000

# MongoDB connection URI (primary key read by database.js)
# Format: mongodb://[user:pass@]host[:port]/dbname
# For Atlas: mongodb+srv://user:pass@cluster.mongodb.net/dbname
DB_URI=mongodb://localhost:27017/stacks_monetization

# JWT secret — use a long random string in production (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=24h

# ============================================================
# OPTIONAL — Defaults are provided when not set
# ============================================================

NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Legacy alias for DB_URI (used as fallback if DB_URI is unset)
MONGODB_URI=mongodb://localhost:27017/stacks_monetization

# MongoDB connection pool and retry tuning (all optional)
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=2
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_CONNECT_RETRIES=3
MONGO_CONNECT_RETRY_DELAY_MS=3000

# IPFS Pinning Service Configuration
# Pinata (Primary provider)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret_api_key

# Web3.Storage (Secondary provider)
WEB3_STORAGE_TOKEN=your_web3_storage_token

# NFT.Storage (Tertiary provider)
NFT_STORAGE_API_KEY=your_nft_storage_api_key

# Infura (Fallback provider)
INFURA_PROJECT_ID=your_infura_project_id
INFURA_PROJECT_SECRET=your_infura_project_secret

# Pinning Service Settings
PINNING_REDUNDANCY_LEVEL=2
PINNING_HEALTH_CHECK_INTERVAL=300000
PINNING_MAX_RETRIES=3
PINNING_TIMEOUT=300000

# Blockchain Configuration
STACKS_API_URL=https://stacks-node-api.mainnet.stacks.co
STACKS_NETWORK=testnet
CONTRACT_ADDRESS=your_contract_address
CREATOR_PRIVATE_KEY=your_private_key
GAIA_HUB_URL=hub.blockstack.org

# AWS S3 Configuration (for file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# Stripe Configuration (for payments)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Ethereum/Polygon Configuration
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
POLYGON_RPC_URL=https://polygon-rpc.com

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Webhook Configuration
WEBHOOK_SECRET=change-me-to-a-secure-value
WEBHOOK_RETRY_ATTEMPTS=3

# Rate Limiting Configuration
RATE_LIMIT_CACHE_TTL=600
RATE_LIMIT_DEFAULT_TIER=free
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STRICT_MODE=false

# Analytics Configuration
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=90

# CDN Configuration
CDN_ENABLED=true
CDN_PROVIDER=cloudflare
CDN_API_KEY=your_cdn_api_key

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30

# Security Configuration
ENCRYPTION_KEY=your-32-character-encryption-key
SESSION_SECRET=your-session-secret-key

# Monitoring Configuration
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn