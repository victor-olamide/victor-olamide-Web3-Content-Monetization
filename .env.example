# Environment Variable Reference
# Copy to .env and fill in real values — never commit the .env file

# MongoDB Authentication (required — no defaults)
MONGO_APP_USERNAME=your_mongo_username
MONGO_APP_PASSWORD=your_mongo_password
MONGO_AUTH_SOURCE=admin

# MongoDB Connection
MONGODB_URI=
MONGO_HOSTS=mongodb-primary:27017,mongodb-secondary1:27017,mongodb-secondary2:27017
MONGO_DATABASE=web3content
MONGO_REPLICA_SET_NAME=rs0

# MongoDB SSL (recommended in production)
MONGO_SSL_ENABLED=false

# Contract Deployment
DEPLOYER_MNEMONIC=your_mnemonic_here

# Docker Registry
DOCKER_USERNAME=your_docker_username
DOCKER_PASSWORD=your_docker_password

# Vercel
VERCEL_TOKEN=your_vercel_token
VERCEL_ORG_ID=your_org_id
VERCEL_PROJECT_ID=your_project_id