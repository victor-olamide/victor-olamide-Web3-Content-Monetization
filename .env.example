# Deployment Secrets Example
# Copy this file to .env and fill in real values — never commit the .env file

# Contract Deployment (required)
DEPLOYER_MNEMONIC=word1 word2 word3 ... word24
DEPLOYER_ADDRESS=SPxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STACKS_NODE_URL=https://api.mainnet.hiro.so
STACKS_MODULES_PATH=/path/to/stacks/node_modules

# Set to true to validate config without broadcasting transactions
DRY_RUN=false

# Docker Registry (CI/CD secrets — store in GitHub Actions secrets, not in .env)
DOCKER_USERNAME=your_docker_username
DOCKER_PASSWORD=your_docker_password

# Vercel
VERCEL_TOKEN=your_vercel_token
VERCEL_ORG_ID=your_org_id
VERCEL_PROJECT_ID=your_project_id