# Environment Variable Reference — copy to .env and fill in real values

# Moderation & Admin Access
# Comma-separated Stacks addresses — whitespace around commas is automatically trimmed
AUTHORIZED_MODERATORS=SP...,SP...
AUTHORIZED_ADMINS=SP...

# Contract Deployment
DEPLOYER_MNEMONIC=your_mnemonic_here

# Docker Registry
DOCKER_USERNAME=your_docker_username
DOCKER_PASSWORD=your_docker_password

# Vercel
VERCEL_TOKEN=your_vercel_token
VERCEL_ORG_ID=your_org_id
VERCEL_PROJECT_ID=your_project_id