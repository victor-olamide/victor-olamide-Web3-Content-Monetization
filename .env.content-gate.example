# Content-Gate Environment Configuration Template
# 
# Copy this file to .env.content-gate and fill in your values
# Used for content-gate contract deployment and integration

# ============================================================================
# STACKS BLOCKCHAIN CONFIGURATION
# ============================================================================

# Network selection: 'testnet' or 'mainnet'
STACKS_NETWORK=testnet

# Stacks API endpoint (testnet)
STACKS_API_URL=https://stacks-node-api.testnet.stacks.co

# Private key for contract deployment (hex format, 0x prefix optional)
# IMPORTANT: Never commit this to version control!
STACKS_PRIVATE_KEY=

# Contract deployment configuration
CONTENT_GATE_ADDRESS=
CONTENT_GATE_CONTRACT=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.content-gate

# ============================================================================
# CONTENT-GATE SERVICE CONFIGURATION
# ============================================================================

# Transaction indexer polling interval (milliseconds)
# Determines how frequently the indexer checks for new gating rule changes
CG_INDEXER_INTERVAL_MS=30000

# API timeout for Stacks API calls (milliseconds)
STACKS_API_TIMEOUT=30000

# Cache configuration
# TTL for gating rule cache (milliseconds, 10 minutes default)
GATING_CACHE_TTL=600000

# Maximum cache size (number of entries)
GATING_CACHE_MAX_SIZE=1000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# MongoDB connection URI
# Format: mongodb://[username]:[password]@[host]:[port]/[database]
MONGODB_URI=mongodb://localhost:27017/content-monetization

# Database name (fallback if not specified in URI)
DB_NAME=content-monetization

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level: 'debug', 'info', 'warn', 'error'
LOG_LEVEL=info

# Enable detailed logging for transaction indexer
INDEXER_VERBOSE_LOGGING=false

# Enable detailed logging for verification operations
VERIFICATION_VERBOSE_LOGGING=false

# ============================================================================
# GATING RULE CONFIGURATION
# ============================================================================

# Default cache TTL for gating verification results
GATING_VERIFICATION_CACHE_TTL=300000

# Enable on-chain rule verification (recommended: true)
ENABLE_ONCHAIN_VERIFICATION=true

# Fallback to database rules if on-chain rules not found
FALLBACK_TO_DB_RULES=true

# ============================================================================
# TEST CONFIGURATION
# ============================================================================

# Test network gating rule for testing
TEST_CONTENT_ID=1
TEST_GATING_TYPE=0
TEST_TOKEN_THRESHOLD=1000000

# Test NFT contract address (optional, for NFT gating tests)
TEST_NFT_CONTRACT=

# Test FT contract address (optional, for FT gating tests)
TEST_FT_CONTRACT=

# ============================================================================
# MONITORING & METRICS
# ============================================================================

# Enable metrics collection
ENABLE_METRICS=true

# Metrics export interval (milliseconds)
METRICS_EXPORT_INTERVAL=60000

# ============================================================================
# SMART CONTRACT ADDRESSES
# ============================================================================

# Pay-per-view contract address (required for content verification)
PPV_CONTRACT=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.pay-per-view

# SIP-010 trait address (for FT verification)
SIP_010_TRAIT=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.sip-010-trait

# SIP-009 trait address (for NFT verification)
SIP_009_TRAIT=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.sip-009-trait

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable FT (fungible token) gating
ENABLE_FT_GATING=true

# Enable NFT gating
ENABLE_NFT_GATING=true

# Enable gating rule caching
ENABLE_GATING_CACHE=true

# Enable transaction indexer
ENABLE_INDEXER=true

# ============================================================================
# ERROR HANDLING
# ============================================================================

# Max retries for API calls
MAX_API_RETRIES=3

# Initial retry delay (exponential backoff, milliseconds)
RETRY_DELAY_MS=1000

# Max retry delay (cap for exponential backoff, milliseconds)
MAX_RETRY_DELAY_MS=10000

# Continue on verification errors (graceful degradation)
CONTINUE_ON_ERROR=false

# ============================================================================
# DOCUMENTATION & EXAMPLES
# ============================================================================

# Example: Fungible Token (FT) Gating Rule
# - GATING_TYPE_FT = 0
# - Users need to hold a minimum balance of a specific token
# - Example: "User must hold 1000 of token ABC to access content"

# Example: Non-Fungible Token (NFT) Gating Rule
# - GATING_TYPE_NFT = 1
# - Users need to own a specific NFT from a collection
# - Example: "User must own at least 1 NFT from collection XYZ to access content"

# Gating Type Constants:
# - 0 = FT (Fungible Token, SIP-010)
# - 1 = NFT (Non-Fungible Token, SIP-009)

# ============================================================================
# DEPLOYMENT INSTRUCTIONS
# ============================================================================

# 1. Copy this file:
#    cp .env.content-gate.example .env.content-gate

# 2. Fill in required values:
#    - STACKS_PRIVATE_KEY (for deployment)
#    - MONGODB_URI (if different from default)
#    - Test values (for integration tests)

# 3. Deploy contract:
#    STACKS_NETWORK=testnet node blockchain/scripts/deploy-cg-testnet.js

# 4. Update CONTENT_GATE_ADDRESS from deployment output:
#    CONTENT_GATE_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.content-gate

# 5. Start backend server:
#    node backend/server.js

# 6. Run integration tests:
#    npm run test:cg-integration

# ============================================================================
