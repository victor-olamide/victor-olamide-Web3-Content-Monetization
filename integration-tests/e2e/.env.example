# E2E Test Environment Configuration Template

# Frontend URL - where the React/Next.js app runs
# Default: http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Backend API URL - where Express server runs
# Default: http://localhost:3001
API_URL=http://localhost:3001

# MongoDB Connection String for test database
# Uses in-memory MongoDB when MONGODB_URI is not set or uses MongoMemoryServer
MONGODB_URI=mongodb://localhost:27017/web3-content-test

# Test Admin Credentials (for admin panel tests)
ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=AdminPassword123!

# Test User Credentials (for user flow tests)
TEST_USER_EMAIL=testuser@test.com
TEST_USER_PASSWORD=TestPassword123!

# Test Creator Credentials
TEST_CREATOR_EMAIL=testcreator@test.com
TEST_CREATOR_PASSWORD=CreatorPassword123!

# Stacks Blockchain Configuration
# Testnet: https://testnet.stacks.co
# Mainnet: https://mainnet.stacks.co
STACKS_NETWORK=testnet
STACKS_API_URL=https://testnet-api.stacks.co
STACKS_RPC_URL=http://localhost:20443

# Wallet Configuration
# For testing with real wallet integrations
HIRO_WALLET_TESTNET_ADDRESS=ST1234567890ABCDEFGHIJ
LEATHER_WALLET_TESTNET_ADDRESS=ST0987654321FEDCBAZYXW

# JWT Configuration
JWT_SECRET=test-jwt-secret-key-change-in-production
JWT_EXPIRY=24h

# Redis Configuration (if applicable)
REDIS_URL=redis://localhost:6379

# Email Configuration (for testing email flows)
EMAIL_SERVICE=smtp
SMTP_HOST=smtp.test.com
SMTP_PORT=587
SMTP_USER=test@test.com
SMTP_PASSWORD=password

# File Upload Configuration
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600  # 100MB

# Payment Gateway Configuration
PAYMENT_PROVIDER=stripe
STRIPE_PUBLIC_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx

# Platform Fee Configuration (in percentage)
PLATFORM_FEE=15

# Content Moderation Configuration
MODERATION_ENABLED=true
AUTO_APPROVE_THRESHOLD=0.8  # 80% confidence

# Logging Configuration
LOG_LEVEL=debug
LOG_FORMAT=json

# Feature Flags for Testing
FEATURE_FLAG_PPV_ENABLED=true
FEATURE_FLAG_SUBSCRIPTIONS_ENABLED=true
FEATURE_FLAG_NFT_ENABLED=true
FEATURE_FLAG_RATINGS_ENABLED=true

# Browser Configuration for Playwright
# Options: chromium, firefox, webkit
BROWSER=chromium
HEADLESS=true
SLOW_MO=0  # Milliseconds to slow down actions (useful for debugging)

# Playwright Configuration
PLAYWRIGHT_TEST_TIMEOUT=30000  # 30 seconds
PLAYWRIGHT_ASSERTION_TIMEOUT=10000  # 10 seconds
PLAYWRIGHT_RETRIES=0  # Number of retries for failed tests

# Debug Configuration
DEBUG=false
VERBOSE_LOGGING=false

# Parallel Execution
MAX_WORKERS=4  # Number of parallel test workers

# Video/Screenshot Configuration
CAPTURE_SCREENSHOTS=false-only  # Options: true, false, only-on-failure
CAPTURE_VIDEO=false  # Options: true, false, retain-on-failure

# Proxy Configuration (if needed)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# Custom Headers for API Requests
API_AUTH_HEADER=Authorization
API_AUTH_PREFIX=Bearer

# Test Data Retention
KEEP_TEST_DATA=false  # Set to true to keep test data after tests
DELETE_TEST_USERS_ON_COMPLETION=true

# Report Configuration
REPORT_DIR=./test-results
REPORT_FORMAT=html,json,junit

# Notification Configuration (for CI/CD)
NOTIFY_ON_FAILURE=true
FAILURE_WEBHOOK_URL=

# Performance Baseline (for regression testing)
PERF_BASELINE_FILE=./performance-baseline.json
MAX_PAGE_LOAD_TIME=3000  # milliseconds
MAX_API_RESPONSE_TIME=1000  # milliseconds

# Custom Test Configuration
CUSTOM_TIMEOUT=5000
CUSTOM_RETRIES=2
SEED_TEST_DATA=true

# Notes:
# - Copy this file to .env or .env.test in integration-tests/ directory
# - Do NOT commit actual .env file with real credentials
# - Update values based on your local setup
# - For CI/CD, use environment variables instead of .env file
# - Ensure all required services (MongoDB, Redis, etc.) are running
# - Use test/staging credentials, never production credentials
