# Smoke Test Environment Variables (#195)
# Copy to .env.smoke and fill in values before running locally.

# URL of the deployed backend to test against
DEPLOYMENT_URL=http://localhost:5000

# Target environment (development | staging | production)
NODE_ENV=development

# Override timeout per run (ms) — defaults come from deployment-config.yml
# SMOKE_TIMEOUT=45000

# Override retry count per run
# SMOKE_RETRIES=3
